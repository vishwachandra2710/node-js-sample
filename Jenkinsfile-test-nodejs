pipeline {
    agent any

    parameters {
        string(name: 'GIT_REPO', defaultValue: 'https://github.com/vishwachandra2710/node-js-sample.git', description: 'Git Repo')
    }

    stages {

        stage('Clone') {
            steps {
                git url: "${params.GIT_REPO}"
            }
        }

        stage('Build Docker Image') {
            steps {
                bat 'docker build -t test-nodejs:v1 -f Dockerfile .'
            }
        }

        stage('Run Container') {
            steps {
                bat 'docker run -d -p 7878:8000 test-nodejs:v1'
            }
        }
    }
}