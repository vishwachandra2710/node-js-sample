pipeline {
    agent any

    stages {

        stage('Clone') {
            steps {
                git url: "${params.GIT_REPO}"
            }
        }

        stage('Install Dependencies') {
            steps {
                bat 'npm install'
            }
        }

        stage('Run App') {
            steps {
                bat 'node index.js'
            }
        }
    }
}